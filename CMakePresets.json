{
    "version": 4,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 24,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "msvc-relwithdebinfo",
            "displayName": "MSVC (RelWithDebInfo)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/cmake-build-${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_C_FLAGS_RELWITHDEBINFO": "/MT",
                "CMAKE_CXX_FLAGS_RELWITHDEBINFO": "/MT"
            }
        },
        {
            "name": "msvc-debug",
            "displayName": "MSVC (Debug)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/cmake-build-${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_C_FLAGS_DEBUG": "/MT",
                "CMAKE_CXX_FLAGS_DEBUG": "/MT"
            }
        },
        {
            "name": "clang-relwithdebinfo",
            "displayName": "Clang (RelWithDebInfo, libc++)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/cmake-build-${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-stdlib=libc++"
            }
        },
        {
            "name": "clang-debug",
            "displayName": "Clang (Debug, libc++)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/cmake-build-${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-stdlib=libc++"
            }
        },
        {
            "name": "clang-debug-sanitizer",
            "displayName": "Clang (Debug, libc++, sanitizers)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/cmake-build-${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-stdlib=libc++",
                "SANITIZE": "yes"
            }
        },
        {
            "name": "musl-cross-base",
            "hidden": true,
            "description": "Shared settings for zig-based musl cross presets. zig cc / c++ is a self-contained cross toolchain; the concrete presets add -target <triple> and the matching CMAKE_SYSTEM_PROCESSOR (the only source for the Conan arch).",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/cmake-build-${presetName}",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "Linux"
            }
        },
        {
            "name": "musl-cross-x86_64-relwithdebinfo",
            "displayName": "musl cross x86_64 (RelWithDebInfo)",
            "inherits": "musl-cross-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_C_COMPILER": "zig;cc;-target;x86_64-linux-musl",
                "CMAKE_CXX_COMPILER": "zig;c++;-target;x86_64-linux-musl",
                "CMAKE_SYSTEM_PROCESSOR": "x86_64"
            }
        },
        {
            "name": "musl-cross-x86_64-debug",
            "displayName": "musl cross x86_64 (Debug)",
            "inherits": "musl-cross-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "zig;cc;-target;x86_64-linux-musl",
                "CMAKE_CXX_COMPILER": "zig;c++;-target;x86_64-linux-musl",
                "CMAKE_SYSTEM_PROCESSOR": "x86_64"
            }
        },
        {
            "name": "musl-cross-aarch64-relwithdebinfo",
            "displayName": "musl cross aarch64 (RelWithDebInfo)",
            "inherits": "musl-cross-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_C_COMPILER": "zig;cc;-target;aarch64-linux-musl",
                "CMAKE_CXX_COMPILER": "zig;c++;-target;aarch64-linux-musl",
                "CMAKE_SYSTEM_PROCESSOR": "aarch64"
            }
        },
        {
            "name": "musl-cross-aarch64-debug",
            "displayName": "musl cross aarch64 (Debug)",
            "inherits": "musl-cross-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "zig;cc;-target;aarch64-linux-musl",
                "CMAKE_CXX_COMPILER": "zig;c++;-target;aarch64-linux-musl",
                "CMAKE_SYSTEM_PROCESSOR": "aarch64"
            }
        },
        {
            "name": "musl-cross-arm-relwithdebinfo",
            "displayName": "musl cross arm (RelWithDebInfo)",
            "inherits": "musl-cross-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_C_COMPILER": "zig;cc;-target;arm-linux-musleabihf",
                "CMAKE_CXX_COMPILER": "zig;c++;-target;arm-linux-musleabihf",
                "CMAKE_SYSTEM_PROCESSOR": "armv7"
            }
        },
        {
            "name": "musl-cross-arm-debug",
            "displayName": "musl cross arm (Debug)",
            "inherits": "musl-cross-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "zig;cc;-target;arm-linux-musleabihf",
                "CMAKE_CXX_COMPILER": "zig;c++;-target;arm-linux-musleabihf",
                "CMAKE_SYSTEM_PROCESSOR": "armv7"
            }
        },
        {
            "name": "musl-cross-mips-relwithdebinfo",
            "displayName": "musl cross mips (RelWithDebInfo)",
            "inherits": "musl-cross-base",
            "description": "-mips-tail-calls=1 re-enables the sibling-call optimisation LLVM disables by default on MIPS. C++20 coroutine symmetric transfer (returning a coroutine_handle from await_suspend) relies on it, so without the flag a deep Task chain grows the stack unboundedly. It is unsafe only across shared-object boundaries, and NLC links its mips deps statically.",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_C_COMPILER": "zig;cc;-target;mips-linux-musleabi;-mllvm;-mips-tail-calls=1",
                "CMAKE_CXX_COMPILER": "zig;c++;-target;mips-linux-musleabi;-mllvm;-mips-tail-calls=1",
                "CMAKE_SYSTEM_PROCESSOR": "mips"
            }
        },
        {
            "name": "musl-cross-mips-debug",
            "displayName": "musl cross mips (Debug)",
            "inherits": "musl-cross-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "zig;cc;-target;mips-linux-musleabi;-mllvm;-mips-tail-calls=1",
                "CMAKE_CXX_COMPILER": "zig;c++;-target;mips-linux-musleabi;-mllvm;-mips-tail-calls=1",
                "CMAKE_SYSTEM_PROCESSOR": "mips"
            }
        },
        {
            "name": "musl-cross-mipsel-relwithdebinfo",
            "displayName": "musl cross mipsel (RelWithDebInfo)",
            "inherits": "musl-cross-base",
            "description": "-mips-tail-calls=1 re-enables the sibling-call optimisation LLVM disables by default on MIPS. C++20 coroutine symmetric transfer (returning a coroutine_handle from await_suspend) relies on it, so without the flag a deep Task chain grows the stack unboundedly. It is unsafe only across shared-object boundaries, and NLC links its mips deps statically.",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_C_COMPILER": "zig;cc;-target;mipsel-linux-musleabi;-mllvm;-mips-tail-calls=1",
                "CMAKE_CXX_COMPILER": "zig;c++;-target;mipsel-linux-musleabi;-mllvm;-mips-tail-calls=1",
                "CMAKE_SYSTEM_PROCESSOR": "mipsel"
            }
        },
        {
            "name": "musl-cross-mipsel-debug",
            "displayName": "musl cross mipsel (Debug)",
            "inherits": "musl-cross-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "zig;cc;-target;mipsel-linux-musleabi;-mllvm;-mips-tail-calls=1",
                "CMAKE_CXX_COMPILER": "zig;c++;-target;mipsel-linux-musleabi;-mllvm;-mips-tail-calls=1",
                "CMAKE_SYSTEM_PROCESSOR": "mipsel"
            }
        },
        {
            "name": "Configure preset using toolchain file",
            "displayName": "Configure preset using toolchain file",
            "description": "Sets Ninja generator, build and install directory",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}"
            }
        },
        {
            "name": "Custom configure preset",
            "displayName": "Custom configure preset",
            "description": "Sets Ninja generator, build and install directory",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}"
            }
        }
    ]
}