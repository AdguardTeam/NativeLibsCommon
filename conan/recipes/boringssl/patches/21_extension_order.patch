diff --git a/ssl/extensions.cc b/ssl/extensions.cc
index 8820497..966fa16 100644
--- a/ssl/extensions.cc
+++ b/ssl/extensions.cc
@@ -3420,6 +3420,38 @@ static_assert(kNumExtensions <=
               "too many extensions for received bitset");
 
 bool ssl_setup_extension_permutation(SSL_HANDSHAKE *hs) {
+  // A pinned extension order takes precedence over both the default order and
+  // the random permutation. The listed extension types are placed first, in the
+  // given order; any remaining supported extensions keep their kExtensions table
+  // order. Unknown or duplicate entries in the list are ignored.
+  const Array<uint16_t> &extension_order = hs->config->extension_order;
+  if (!extension_order.empty()) {
+    static_assert(kNumExtensions <= UINT8_MAX,
+                  "extensions_permutation type is too small");
+    Array<uint8_t> permutation;
+    if (!permutation.Init(kNumExtensions)) {
+      return false;
+    }
+    bool seen[kNumExtensions] = {false};
+    size_t idx = 0;
+    for (uint16_t value : extension_order) {
+      for (size_t j = 0; j < kNumExtensions; j++) {
+        if (kExtensions[j].value == value && !seen[j]) {
+          seen[j] = true;
+          permutation[idx++] = static_cast<uint8_t>(j);
+          break;
+        }
+      }
+    }
+    for (size_t j = 0; j < kNumExtensions; j++) {
+      if (!seen[j]) {
+        permutation[idx++] = static_cast<uint8_t>(j);
+      }
+    }
+    hs->extension_permutation = std::move(permutation);
+    return true;
+  }
+
   if (!hs->config->permute_extensions) {
     return true;
   }
