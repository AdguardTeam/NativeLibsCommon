diff --git a/ssl/extensions.cc b/ssl/extensions.cc
--- a/ssl/extensions.cc
+++ b/ssl/extensions.cc
@@ -2764,7 +2764,23 @@
 static bool ext_delegated_credential_add_clienthello(
     const SSL_HANDSHAKE *hs, CBB *out, CBB *out_compressible,
     ssl_client_hello_type_t type) {
-  return true;
+  // Advertise the delegated_credential extension when configured.
+  if (hs->config->delegated_credentials.empty()) {
+    return true;
+  }
+
+  CBB contents, sigalgs;
+  if (!CBB_add_u16(out, TLSEXT_TYPE_delegated_credential) ||
+      !CBB_add_u16_length_prefixed(out, &contents) ||
+      !CBB_add_u16_length_prefixed(&contents, &sigalgs)) {
+    return false;
+  }
+  for (uint16_t alg : hs->config->delegated_credentials) {
+    if (!CBB_add_u16(&sigalgs, alg)) {
+      return false;
+    }
+  }
+  return CBB_flush(out);
 }
 
